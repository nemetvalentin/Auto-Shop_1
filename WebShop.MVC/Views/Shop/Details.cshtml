@model WebShop.MVC.ViewModels.ProductViewModel
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Shop">Prodavnica</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-5 text-center">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" class="img-fluid rounded shadow" style="max-height:350px; object-fit:contain" alt="@Model.Name" />
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center bg-light rounded" style="height:300px">
                <i class="bi bi-car-front text-secondary" style="font-size:6rem"></i>
            </div>
        }
    </div>
    <div class="col-md-7">
        <span class="badge bg-secondary mb-2">@Model.CategoryName</span>
        <h1 class="fw-bold">@Model.Name</h1>
        <p class="text-muted small mb-1">Šifra: <strong>@Model.Code</strong></p>
        <hr />
        <p class="lead">@Model.Description</p>
        <hr />
        <div class="fs-2 fw-bold text-primary mb-3">@Model.Price.ToString("N2") €</div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="Add" asp-controller="Cart" method="post" class="d-flex align-items-center gap-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="d-flex align-items-center gap-2">
                    <label class="fw-semibold">Količina:</label>
                    <input type="number" name="quantity" value="1" min="1" max="99" class="form-control" style="width:80px" />
                </div>
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-cart-plus"></i> Dodaj u korpu
                </button>
            </form>
        }
        else
        {
            <a asp-action="Login" asp-controller="Account" class="btn btn-success btn-lg">
                <i class="bi bi-cart-plus"></i> Prijavite se za kupovinu
            </a>
        }

        <div class="mt-3">
            <a asp-action="Index" asp-controller="Shop" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Nazad na prodavnicu
            </a>
        </div>
    </div>
</div>
