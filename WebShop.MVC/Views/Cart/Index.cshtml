@model WebShop.MVC.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Korpa";
}

<h2 class="mb-4"><i class="bi bi-cart3"></i> Moja korpa</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Items.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x text-muted" style="font-size:5rem"></i>
        <h4 class="mt-3 text-muted">Vaša korpa je prazna</h4>
        <a asp-action="Index" asp-controller="Shop" class="btn btn-primary mt-3">
            <i class="bi bi-shop"></i> Idite u prodavnicu
        </a>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Proizvod</th>
                                <th class="text-center">Cena</th>
                                <th class="text-center">Količina</th>
                                <th class="text-center">Ukupno</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="align-middle">
                                        <div class="fw-semibold">@item.ProductName</div>
                                        <small class="text-muted">@item.ProductCode</small>
                                    </td>
                                    <td class="align-middle text-center">@item.UnitPrice.ToString("N2") €</td>
                                    <td class="align-middle text-center">
                                        <form asp-action="UpdateQuantity" asp-controller="Cart" method="post" class="d-flex align-items-center justify-content-center gap-1">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="99" class="form-control form-control-sm text-center" style="width:65px" onchange="this.form.submit()" />
                                        </form>
                                    </td>
                                    <td class="align-middle text-center fw-bold text-primary">@item.TotalPrice.ToString("N2") €</td>
                                    <td class="align-middle text-center">
                                        <form asp-action="Remove" asp-controller="Cart" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Ukloniti proizvod iz korpe?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="mt-3">
                <a asp-action="Index" asp-controller="Shop" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Nastavi kupovinu
                </a>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-receipt"></i> Pregled porudžbine
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Broj artikala:</span>
                        <span>@Model.TotalCount</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Ukupno:</span>
                        <span class="text-primary">@Model.TotalAmount.ToString("N2") €</span>
                    </div>
                    <div class="mt-3">
                        <a asp-action="Checkout" asp-controller="Cart" class="btn btn-success w-100 btn-lg">
                            <i class="bi bi-credit-card"></i> Nastavi na naplatu
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
