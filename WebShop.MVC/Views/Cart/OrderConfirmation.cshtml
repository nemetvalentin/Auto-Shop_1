@model WebShop.MVC.ViewModels.OrderViewModel
@{
    ViewData["Title"] = "Porudžbina potvrđena";
}

<div class="text-center py-4">
    <div class="display-1 text-success mb-3"><i class="bi bi-check-circle-fill"></i></div>
    <h2 class="fw-bold">Hvala vam na porudžbini!</h2>
    <p class="text-muted fs-5">Porudžbina <strong>#@Model.Id</strong> je uspešno kreirana.</p>
    <p class="text-muted">Datum: @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold"><i class="bi bi-list-check"></i> Detalji porudžbine</div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Status:</div>
                    <div class="col-sm-8"><span class="badge bg-warning text-dark">@Model.Status</span></div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted">Adresa dostave:</div>
                    <div class="col-sm-8">@Model.ShippingAddress</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Napomena:</div>
                        <div class="col-sm-8">@Model.Notes</div>
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold"><i class="bi bi-bag"></i> Naručeni artikli</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Proizvod</th>
                            <th class="text-center">Kol.</th>
                            <th class="text-end">Jed. cena</th>
                            <th class="text-end">Ukupno</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName<br /><small class="text-muted">@item.ProductCode</small></td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("N2") €</td>
                                <td class="text-end fw-semibold">@item.TotalPrice.ToString("N2") €</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold fs-5">
                            <td colspan="3">Ukupno:</td>
                            <td class="text-end text-primary">@Model.TotalAmount.ToString("N2") €</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-center">
            <a asp-action="MyOrders" asp-controller="Order" class="btn btn-outline-primary">
                <i class="bi bi-clock-history"></i> Moje porudžbine
            </a>
            <a asp-action="Index" asp-controller="Shop" class="btn btn-primary">
                <i class="bi bi-shop"></i> Nastavi kupovinu
            </a>
        </div>
    </div>
</div>
