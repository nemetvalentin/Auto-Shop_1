@model WebShop.MVC.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Potvrda porudžbine";
}

<h2 class="mb-4"><i class="bi bi-bag-check"></i> Potvrda porudžbine</h2>

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold">Podaci za dostavu</div>
            <div class="card-body">
                <form asp-action="ConfirmOrder" asp-controller="Cart" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                    <div class="mb-3">
                        <label asp-for="ShippingAddress" class="form-label fw-semibold"></label>
                        <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Ulica i broj, grad, poštanski broj..."></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Opciona napomena..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-check-circle"></i> Potvrdi porudžbinu (@Model.TotalAmount.ToString("N2") €)
                    </button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Pregled artikala</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Naziv</th>
                            <th class="text-center">Kol.</th>
                            <th class="text-end">Ukupno</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr>
                                <td><small>@item.ProductName</small></td>
                                <td class="text-center"><small>@item.Quantity</small></td>
                                <td class="text-end"><small>@item.TotalPrice.ToString("N2") €</small></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="2">Ukupno:</td>
                            <td class="text-end text-primary">@Model.TotalAmount.ToString("N2") €</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
        <a asp-action="Index" asp-controller="Cart" class="btn btn-outline-secondary w-100 mt-2">
            <i class="bi bi-arrow-left"></i> Nazad na korpu
        </a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
