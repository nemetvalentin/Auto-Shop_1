@model WebShop.MVC.ViewModels.OrderViewModel
@{
    ViewData["Title"] = $"Porudžbina #{Model.Id}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        @if (User.IsInRole("Admin"))
        {
            <li class="breadcrumb-item"><a asp-action="AllOrders" asp-controller="Order">Sve porudžbine</a></li>
        }
        else
        {
            <li class="breadcrumb-item"><a asp-action="MyOrders" asp-controller="Order">Moje porudžbine</a></li>
        }
        <li class="breadcrumb-item active">Porudžbina #@Model.Id</li>
    </ol>
</nav>

<h2 class="mb-4"><i class="bi bi-receipt"></i> Porudžbina #@Model.Id</h2>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-bold">Informacije</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Datum:</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                    @if (Model.Username != null)
                    {
                        <dt class="col-sm-5 text-muted">Korisnik:</dt>
                        <dd class="col-sm-7">@Model.Username</dd>
                    }
                    <dt class="col-sm-5 text-muted">Status:</dt>
                    <dd class="col-sm-7">
                        @{
                            var badgeClass = Model.Status switch
                            {
                                "Pending" => "bg-warning text-dark",
                                "Processing" => "bg-info text-dark",
                                "Shipped" => "bg-primary",
                                "Delivered" => "bg-success",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@Model.Status</span>
                    </dd>
                    <dt class="col-sm-5 text-muted">Dostava:</dt>
                    <dd class="col-sm-7">@Model.ShippingAddress</dd>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <dt class="col-sm-5 text-muted">Napomena:</dt>
                        <dd class="col-sm-7">@Model.Notes</dd>
                    }
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-8 mb-3">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Naručeni artikli</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Proizvod</th>
                            <th class="text-center">Kol.</th>
                            <th class="text-end">Jed. cena</th>
                            <th class="text-end">Ukupno</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    @item.ProductName<br />
                                    <small class="text-muted">@item.ProductCode</small>
                                </td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("N2") €</td>
                                <td class="text-end fw-semibold">@item.TotalPrice.ToString("N2") €</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold fs-5 table-light">
                            <td colspan="3">Ukupno:</td>
                            <td class="text-end text-primary">@Model.TotalAmount.ToString("N2") €</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <div class="card shadow-sm">
        <div class="card-header fw-bold">Promena statusa</div>
        <div class="card-body">
            <form asp-action="UpdateStatus" asp-controller="Order" method="post" class="d-flex gap-3 align-items-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.Id" />
                <select name="status" class="form-select" style="width:200px">
                    <option value="Pending" selected="@(Model.Status == "Pending")">Na čekanju</option>
                    <option value="Processing" selected="@(Model.Status == "Processing")">U obradi</option>
                    <option value="Shipped" selected="@(Model.Status == "Shipped")">Poslato</option>
                    <option value="Delivered" selected="@(Model.Status == "Delivered")">Dostavljeno</option>
                    <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Otkazano</option>
                </select>
                <button type="submit" class="btn btn-primary">Ažuriraj status</button>
            </form>
        </div>
    </div>
}
